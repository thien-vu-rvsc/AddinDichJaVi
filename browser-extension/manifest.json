{
  "manifest_version": 3,
  "name": "JP-VI Translator",
  "version": "1.0.0",
  "description": "Dịch từ vựng và đoạn văn Nhật-Việt trực tiếp trên trình duyệt bằng Google Translate và sinh phiên âm.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  },
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  }
}
